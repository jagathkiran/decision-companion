@startuml
scale 2
skinparam monochrome true
skinparam shadowing false

package "Frontend (React/Vite)" {
  [Wizard Interface] as UI
  [History Manager] as HM
  [Report Generator] as RG
  [State Orchestrator] as SO
}

package "Backend (FastAPI)" {
  [Scoring Engine] as SE
  [Insight Logic] as IL
}

package "Persistence (Browser)" {
  database "localStorage (JSON)" as STORAGE
}

' Interface points
() "REST API" as API
() "Browser Storage API" as STORAGE_API

UI -- SO
SO -- API
API -- SE
SE -- IL

SO -- HM
HM -- STORAGE_API
STORAGE_API -- STORAGE

@enduml
