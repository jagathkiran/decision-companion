@startuml
scale 2
skinparam monochrome true
skinparam shadowing false

title Decision Companion Control Flow (Web)

start

:Define Decision & Category;
:Establish Evaluation Criteria;
:Weight Criteria (1-5);
:Enter Comparison Options;

repeat
  :Score Options against Criteria (1-10);
  :Submit to FastAPI Engine;
  :Generate Rankings & Analysis;
  :Visualize Results;
  
  :Save to localStorage (History);
  :Download Decision Report (Optional);

  if (Refine inputs?) then (Yes)
    :Return to Step 3/4;
  else (No)
    stop
  endif
repeat while (New Decision?) is (Yes)

stop

@enduml
